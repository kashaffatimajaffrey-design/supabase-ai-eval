# Supabase (project settings -> API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-side only, bypasses RLS

# Generation + judge model
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-4-6

# Embeddings — choose one provider
EMBEDDING_PROVIDER=openai          # or "voyage"
OPENAI_API_KEY=your-openai-key
# VOYAGE_API_KEY=your-voyage-key
# EMBEDDING_MODEL=voyage-3-lite    # override if using voyage; update vector(N) dim in schema.sql to match
